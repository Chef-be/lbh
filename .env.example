# ============================================================
# PLATEFORME BEE — Variables d'environnement
# Bureau d'Études Économiste
# ============================================================
# IMPORTANT : Ce fichier est un modèle. Copier sous le nom
# ".env" et remplir avec les valeurs réelles.
# Ne JAMAIS versionner le fichier ".env".
# ============================================================

# ------------------------------------------------------------
# GÉNÉRAL
# ------------------------------------------------------------
ENVIRONNEMENT=developpement
# Valeurs possibles : developpement, recette, production
LANGUE=fr
FUSEAU_HORAIRE=Europe/Paris
NOM_APPLICATION=Plateforme BEE
VERSION_APPLICATION=0.1.0
URL_BASE=https://bee.lbh-economiste.com
# URL utilisée pour les liens dans les courriels et les exports

# ------------------------------------------------------------
# SECRETS — Générer avec : openssl rand -hex 32
# ------------------------------------------------------------
SECRET_DJANGO=CHANGER_MOI_AVEC_UNE_VRAIE_VALEUR_SECRETE
SECRET_NEXTAUTH=CHANGER_MOI_AVEC_UNE_VRAIE_VALEUR_SECRETE
SECRET_MINIO=CHANGER_MOI_AVEC_UNE_VRAIE_VALEUR_SECRETE
CLES_API_AUTORISEES=
# Liste de clés séparées par des virgules pour l'accès API

# ------------------------------------------------------------
# BASE DE DONNÉES PostgreSQL + PostGIS
# ------------------------------------------------------------
BDD_HOTE=bee-postgresql
BDD_PORT=5432
BDD_NOM=bee_production
BDD_UTILISATEUR=bee_appli
BDD_MOT_DE_PASSE=CHANGER_MOI
BDD_SCHEMA=bee
# Pour les tests uniquement
BDD_NOM_TEST=bee_test

# Connexion directe (pour les outils externes uniquement)
DATABASE_URL=postgresql://bee_appli:MOT_DE_PASSE@bee-postgresql:5432/bee_production

# ------------------------------------------------------------
# REDIS — File d'attente et cache
# ------------------------------------------------------------
REDIS_HOTE=bee-redis
REDIS_PORT=6379
REDIS_MOT_DE_PASSE=
# Laisser vide si Redis sans mot de passe
REDIS_BD_CACHE=0
REDIS_BD_CELERY=1
REDIS_BD_SESSION=2
URL_REDIS=redis://bee-redis:6379

# ------------------------------------------------------------
# CELERY — Traitement asynchrone
# ------------------------------------------------------------
CELERY_COURTIER=redis://bee-redis:6379/1
CELERY_RESULTATS=redis://bee-redis:6379/1
CELERY_DELAI_TACHE_MAX=3600
# En secondes
CELERY_TENTATIVES_MAX=3
CELERY_JOURNALISATION_NIVEAU=INFO

# ------------------------------------------------------------
# STOCKAGE OBJET — MinIO
# ------------------------------------------------------------
MINIO_ENDPOINT=bee-minio:9000
MINIO_ACCES_CLE=CHANGER_MOI
MINIO_SECRET_CLE=CHANGER_MOI_AVEC_UNE_VALEUR_LONGUE
MINIO_SSL=false
MINIO_CORBEILLE_DOCUMENTS=bee-documents
MINIO_CORBEILLE_PLANS=bee-plans
MINIO_CORBEILLE_EXPORTS=bee-exports
MINIO_CORBEILLE_MODELES=bee-modeles
MINIO_CORBEILLE_RESSOURCES=bee-ressources
MINIO_CORBEILLE_OCR=bee-ocr-sortie
MINIO_TAILLE_MAX_IMPORT=104857600
# En octets — 100 Mo par défaut

# ------------------------------------------------------------
# AUTHENTIFICATION
# ------------------------------------------------------------
DUREE_SESSION=86400
# En secondes — 24h par défaut
DUREE_TOKEN_ACCESS=3600
# En secondes — 1h par défaut
DUREE_TOKEN_REFRESH=604800
# En secondes — 7 jours par défaut
DOMAINES_AUTORISES=bee.lbh-economiste.com,localhost
# Séparés par des virgules
TENTATIVES_CONNEXION_MAX=5
# Avant verrouillage du compte
DUREE_VERROUILLAGE=1800
# En secondes — 30 minutes par défaut

# ------------------------------------------------------------
# COURRIEL — Configuration SMTP
# ------------------------------------------------------------
COURRIEL_HOTE_SMTP=mail.lbh-economiste.com
COURRIEL_PORT_SMTP=587
COURRIEL_SSL=false
COURRIEL_TLS=true
COURRIEL_UTILISATEUR=bee@lbh-economiste.com
COURRIEL_MOT_DE_PASSE=CHANGER_MOI
COURRIEL_EXPEDITEUR_PAR_DEFAUT=Plateforme BEE <bee@lbh-economiste.com>

# Courriel de l'administrateur (pour les alertes système)
COURRIEL_ADMINISTRATEUR=admin@lbh-economiste.com

# Webmail IMAP (pour le module webmail intégré)
COURRIEL_HOTE_IMAP=mail.lbh-economiste.com
COURRIEL_PORT_IMAP=993
COURRIEL_IMAP_SSL=true

# ------------------------------------------------------------
# SERVICES OCR
# ------------------------------------------------------------
OCR_HOTE=bee-ocr
OCR_PORT=8010
OCR_LANGUES=fra,eng
# Langues Tesseract séparées par des virgules
OCR_DPI_MIN=150
OCR_DPI_OPTIMAL=300
OCR_SEUIL_CONFIANCE=60
# En pourcentage — résultats en dessous signalés comme incertains
OCR_TAILLE_MAX_FICHIER=52428800
# En octets — 50 Mo par défaut

# ------------------------------------------------------------
# SERVICES ANALYSE PDF
# ------------------------------------------------------------
ANALYSE_PDF_HOTE=bee-analyse-pdf
ANALYSE_PDF_PORT=8011
ANALYSE_PDF_TAILLE_MAX=104857600
# En octets — 100 Mo par défaut

# ------------------------------------------------------------
# SERVICES ANALYSE CAO (DWG/DXF)
# ------------------------------------------------------------
ANALYSE_CAO_HOTE=bee-analyse-cao
ANALYSE_CAO_PORT=8012
ANALYSE_CAO_FORMATS_ACCEPTES=dxf,dwg
# Note : DWG requiert ODA File Converter si disponible
# DXF est traité nativement par ezdxf

# ------------------------------------------------------------
# SUPERVISION
# ------------------------------------------------------------
SUPERVISION_ACTIF=true
SUPERVISION_RETENTION_JOURNAUX=30
# En jours
SUPERVISION_SEUIL_CPU=80
# Alerte si CPU > seuil (en pourcentage)
SUPERVISION_SEUIL_MEMOIRE=85
# Alerte si mémoire > seuil (en pourcentage)
SUPERVISION_SEUIL_DISQUE=85
# Alerte si disque > seuil (en pourcentage)

# ------------------------------------------------------------
# CENTRE DE MISE À JOUR
# ------------------------------------------------------------
DEPOT_GIT_URL=
DEPOT_GIT_BRANCHE=main
DEPOT_GIT_CHEMIN_LOCAL=/var/www/vhosts/lbh-economiste.com/httpdocs
# Identifiant SSH pour GitHub (chemin vers la clé privée)
SSH_CLE_DEPOT=

# ------------------------------------------------------------
# PARAMÈTRES MÉTIER — Voirie
# ------------------------------------------------------------
VOIRIE_DUREE_SERVICE_DEFAUT=20
# En années
VOIRIE_TAUX_CROISSANCE_TRAFIC_DEFAUT=2.0
# En pourcentage annuel
VOIRIE_COEFFICIENT_VL_ESSIEUX_EQ=0.0006
# Coefficient de dommage VL (véhicule léger)
VOIRIE_COEFFICIENT_PL_ESSIEUX_EQ=1.0
# Coefficient de dommage PL moyen
VOIRIE_PORTANCE_CBR_MIN=3
# CBR minimum pour platform sans traitement (en %)
VOIRIE_PORTANCE_PLATEFORME_MIN=35
# Module de déformation EV2 minimum (en MPa)

# ------------------------------------------------------------
# PARAMÈTRES MÉTIER — Économie de la construction
# ------------------------------------------------------------
ECONOMIE_HEURES_PRODUCTIVES_ANNUELLES=1600
# Heures productives par ouvrier par an
ECONOMIE_TAUX_CHARGES_SOCIALES=0.85
# Coefficient de charges sociales sur salaire brut
ECONOMIE_TAUX_FRAIS_CHANTIER_DEFAUT=0.12
# Taux de frais de chantier par défaut (12%)
ECONOMIE_TAUX_FRAIS_GENERAUX_DEFAUT=0.10
# Taux de frais généraux par défaut (10%)
ECONOMIE_TAUX_ALEAS_DEFAUT=0.03
# Taux d'aléas par défaut (3%)
ECONOMIE_TAUX_MARGE_CIBLE_DEFAUT=0.08
# Taux de marge cible par défaut (8%)
ECONOMIE_TAUX_PERTES_DEFAUT=0.05
# Taux de pertes matières par défaut (5%)

# Seuils de rentabilité
ECONOMIE_SEUIL_MARGE_ALERTE=0.03
# Marge nette en dessous de laquelle on est "à surveiller"
ECONOMIE_SEUIL_MARGE_DANGER=0.00
# Marge nette en dessous de laquelle on est "non rentable"

# ------------------------------------------------------------
# PARAMÈTRES MÉTIER — Bâtiment encadré
# ------------------------------------------------------------
BATIMENT_CONTRAINTE_SOL_MIN=0.1
# Contrainte admissible minimum du sol (en MPa)
BATIMENT_CONTRAINTE_SOL_MAX=0.5
# Contrainte admissible maximum du sol (en MPa)
BATIMENT_RESISTANCE_MACONNERIE_DEFAUT=5.0
# Résistance caractéristique maçonnerie (en MPa)

# ------------------------------------------------------------
# DOCKER COMPOSE — Ports (à ne modifier que si conflit)
# ------------------------------------------------------------
PORT_ENTREE_PLESK=3082
PORT_MINIO_API=9100
PORT_MINIO_CONSOLE=9101

# ------------------------------------------------------------
# JOURNALISATION
# ------------------------------------------------------------
JOURNALISATION_NIVEAU=INFO
# Valeurs : DEBUG, INFO, WARNING, ERROR, CRITICAL
JOURNALISATION_FICHIER=/var/log/bee/application.log
JOURNALISATION_ROTATION=7
# Jours de rétention

# ------------------------------------------------------------
# DÉVELOPPEMENT UNIQUEMENT
# ------------------------------------------------------------
DEBUG=false
# Toujours false en production
RECHARGEMENT_AUTO=false
# Toujours false en production
AFFICHER_BARRE_DEBUG=false
CORS_ORIGINES_AUTORISEES=http://localhost:3000,http://localhost:3082
