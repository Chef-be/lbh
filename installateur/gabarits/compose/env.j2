# ============================================================
# {{ nom_plateforme }} — Variables d'environnement
# Généré automatiquement par l'installateur le {{ date_installation }}
# NE PAS VERSIONNER CE FICHIER
# ============================================================

# ------------------------------------------------------------
# IDENTITÉ DE LA PLATEFORME
# ------------------------------------------------------------
NOM_PLATEFORME={{ nom_plateforme }}
PREFIXE_CONTENEURS={{ prefixe_conteneurs }}
SLOGAN={{ slogan }}
ENVIRONNEMENT={{ environnement }}
# Valeurs possibles : developpement, recette, production
LANGUE=fr
FUSEAU_HORAIRE={{ fuseau_horaire }}
URL_BASE={{ url_base }}
DEBUG=false
VERSION_APPLICATION=1.0.0

# ------------------------------------------------------------
# PORTS
# ------------------------------------------------------------
PORT_ENTREE_PLESK={{ port_entree_plesk }}
PORT_MINIO_API={{ port_minio_api }}
PORT_MINIO_CONSOLE={{ port_minio_console }}
PORT_POSTGRESQL_LOCAL={{ port_postgresql_local }}

# ------------------------------------------------------------
# SECRETS
# ------------------------------------------------------------
SECRET_DJANGO={{ secret_django }}
SECRET_NEXTAUTH={{ secret_nextauth }}

# ------------------------------------------------------------
# BASE DE DONNÉES
# ------------------------------------------------------------
BDD_HOTE={{ prefixe_conteneurs }}-postgresql
BDD_PORT=5432
BDD_NOM={{ bdd_nom }}
BDD_UTILISATEUR={{ bdd_utilisateur }}
BDD_MOT_DE_PASSE={{ bdd_mot_de_passe }}
BDD_SCHEMA=principal
DATABASE_URL=postgresql://{{ bdd_utilisateur }}:{{ bdd_mot_de_passe }}@{{ prefixe_conteneurs }}-postgresql:5432/{{ bdd_nom }}

# ------------------------------------------------------------
# REDIS
# ------------------------------------------------------------
REDIS_HOTE={{ prefixe_conteneurs }}-redis
REDIS_PORT=6379
REDIS_MOT_DE_PASSE={{ redis_mot_de_passe }}
REDIS_BD_CACHE=0
REDIS_BD_CELERY=1
REDIS_BD_SESSION=2
URL_REDIS=redis://{{ prefixe_conteneurs }}-redis:6379

# ------------------------------------------------------------
# CELERY
# ------------------------------------------------------------
CELERY_COURTIER=redis://{{ prefixe_conteneurs }}-redis:6379/1
CELERY_RESULTATS=redis://{{ prefixe_conteneurs }}-redis:6379/1
CELERY_DELAI_TACHE_MAX=3600
CELERY_TENTATIVES_MAX=3

# ------------------------------------------------------------
# STOCKAGE OBJET — MinIO
# ------------------------------------------------------------
MINIO_ENDPOINT={{ prefixe_conteneurs }}-minio:9000
MINIO_ACCES_CLE={{ minio_acces_cle }}
MINIO_SECRET_CLE={{ minio_secret_cle }}
MINIO_SSL=false
MINIO_CORBEILLE_DOCUMENTS={{ prefixe_conteneurs }}-documents
MINIO_CORBEILLE_PLANS={{ prefixe_conteneurs }}-plans
MINIO_CORBEILLE_EXPORTS={{ prefixe_conteneurs }}-exports
MINIO_CORBEILLE_MODELES={{ prefixe_conteneurs }}-modeles
MINIO_TAILLE_MAX_IMPORT=104857600

# ------------------------------------------------------------
# COURRIEL
# ------------------------------------------------------------
COURRIEL_HOTE_SMTP={{ courriel_hote_smtp }}
COURRIEL_PORT_SMTP={{ courriel_port_smtp }}
COURRIEL_TLS={{ "true" if courriel_tls else "false" }}
# SSL implicite (port 465) — distinct de STARTTLS (port 587)
COURRIEL_SSL={{ "true" if courriel_port_smtp == 465 else "false" }}
COURRIEL_UTILISATEUR={{ courriel_utilisateur }}
COURRIEL_MOT_DE_PASSE={{ courriel_mot_de_passe }}
COURRIEL_EXPEDITEUR_PAR_DEFAUT={{ courriel_expediteur if courriel_expediteur else nom_plateforme + " <" + courriel_utilisateur + ">" }}
COURRIEL_ADMINISTRATEUR={{ courriel_administrateur }}

# ------------------------------------------------------------
# SERVICES SPÉCIALISÉS
# ------------------------------------------------------------
OCR_HOTE={{ prefixe_conteneurs }}-ocr
OCR_PORT=8010
OCR_LANGUES=fra,eng
OCR_DPI_MIN=150
OCR_DPI_OPTIMAL=300
OCR_SEUIL_CONFIANCE=60

ANALYSE_PDF_HOTE={{ prefixe_conteneurs }}-analyse-pdf
ANALYSE_PDF_PORT=8011

ANALYSE_CAO_HOTE={{ prefixe_conteneurs }}-analyse-cao
ANALYSE_CAO_PORT=8012
ANALYSE_CAO_FORMATS_ACCEPTES=dxf,dwg

# ------------------------------------------------------------
# PARAMÈTRES MÉTIER — Voirie
# ------------------------------------------------------------
VRD_DUREE_SERVICE_DEFAUT=20
VRD_TAUX_CROISSANCE_DEFAUT=2.0
VRD_PROFONDEUR_HORS_GEL=0.8

# ------------------------------------------------------------
# PARAMÈTRES MÉTIER — Économie
# ------------------------------------------------------------
ECONO_HEURES_PROD_ANNUELLES=1600
ECONO_TAUX_CHARGES_SOCIALES=0.85
ECONO_TAUX_FRAIS_CHANTIER=0.12
ECONO_TAUX_FRAIS_GENERAUX=0.10
ECONO_TAUX_ALEAS=0.03
ECONO_TAUX_MARGE_CIBLE=0.08
ECONO_TAUX_PERTES=0.05
ECONO_SEUIL_ALERTE_MARGE=0.03
ECONO_TVA_TAUX_NORMAL=0.20
ECONO_TVA_TAUX_TRAVAUX=0.10

# ------------------------------------------------------------
# SUPERVISION
# ------------------------------------------------------------
SUPERVISION_ACTIF=true
SUPERVISION_RETENTION_JOURNAUX=30
SUPERVISION_SEUIL_CPU=80
SUPERVISION_SEUIL_MEMOIRE=85
SUPERVISION_SEUIL_DISQUE=85

# ------------------------------------------------------------
# JOURNALISATION
# ------------------------------------------------------------
JOURNALISATION_NIVEAU=INFO
DOMAINES_AUTORISES={{ url_base.replace("https://", "").replace("http://", "") }},localhost
CORS_ORIGINES_AUTORISEES=http://localhost:3000
